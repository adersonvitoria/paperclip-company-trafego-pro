generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Configurações chave-valor do console (chaves de API, metas, guardrails)
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// Estado por agente (liga/desliga, modelo)
model AgentConfig {
  slug      String   @id
  enabled   Boolean  @default(true)
  model     String   @default("claude-opus-4-8")
  updatedAt DateTime @updatedAt
}

// Leads capturados pelo site comercial (formulário público)
model Lead {
  id           String   @id @default(cuid())
  nome         String
  contato      String   // whatsapp ou e-mail
  segmento     String
  objetivo     String
  verbaMidia   String?
  status       String   @default("NOVO") // NOVO | CONTATADO | GANHO | PERDIDO
  orcamentoJson String? // proposta gerada automaticamente pela IA (JSON)
  origem       String   @default("site")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status])
}

// Lançamentos financeiros — contas a pagar e a receber (valores em centavos)
model FinanceEntry {
  id            String   @id @default(cuid())
  tipo          String   // RECEBER | PAGAR
  descricao     String
  categoria     String?
  valorCents    Int
  vencimento    DateTime
  status        String   @default("PENDENTE") // PENDENTE | QUITADO
  grupoId       String?  // agrupa parcelas / recorrências
  parcelaNum    Int      @default(1)
  parcelasTotal Int      @default(1)
  recorrente    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tipo, status])
  @@index([grupoId])
}

// Execuções de pipeline; steps é um JSON serializado [{skill, agent, output, at}]
model PipelineRun {
  id        String   @id @default(cuid())
  pipeline  String
  briefing  String
  status    String   @default("RUNNING") // RUNNING | DONE | ERROR
  steps     String   @default("[]")
  error     String?
  auto      Boolean  @default(false)     // execução automática em sequência
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
